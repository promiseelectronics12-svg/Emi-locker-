idth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n74b1cf03e4c3" target="ncd23acd7fb67"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n44ae195141d2" value="3. GET /health until DB + Redis are good" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#172554;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="300" width="820" height="105" as="geometry"/></mxCell><mxCell id="nc67e2daea066" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="ncd23acd7fb67" target="n44ae195141d2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="nf8d964cd9a72" value="4. Run/verify migrations and inspect actual schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#172554;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="300" width="820" height="105" as="geometry"/></mxCell><mxCell id="n52b34d2c9df0" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n44ae195141d2" target="nf8d964cd9a72"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n9941b313d83b" value="5. Confirm API prefix: origin + /api/v1 exactly once" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#172554;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="460" width="820" height="105" as="geometry"/></mxCell><mxCell id="n738d60cfe106" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="nf8d964cd9a72" target="n9941b313d83b"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ne3381752e951" value="6. Test auth login and token refresh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#052e16;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="460" width="820" height="105" as="geometry"/></mxCell><mxCell id="n21273ab1ae80" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n9941b313d83b" target="ne3381752e951"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n8cb0a5b92571" value="7. Test admin panel request URLs in browser network tab" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#052e16;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="620" width="820" height="105" as="geometry"/></mxCell><mxCell id="ndec07b80aee9" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="ne3381752e951" target="n8cb0a5b92571"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n82e740c647ec" value="8. Test Flutter API_BASE_URL, login, role workspace, SSE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#052e16;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="620" width="820" height="105" as="geometry"/></mxCell><mxCell id="nf48a9fc8e2b6" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n8cb0a5b92571" target="n82e740c647ec"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="nb3f142c44c8d" value="9. Test Android BuildConfig.API_BASE_URL and device network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#052e16;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="780" width="820" height="105" as="geometry"/></mxCell><mxCell id="ncf95308e444f" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n82e740c647ec" target="nb3f142c44c8d"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="nf7457612e72c" value="10. Test activation: pre-register -&gt; enrollment -&gt; confirm -&gt; FCM token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#052e16;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="780" width="820" height="105" as="geometry"/></mxCell><mxCell id="n584cd8da6866" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="nb3f142c44c8d" target="nf7457612e72c"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n2b13dbc88532" value="11. Test lock command: route -&gt; DB -&gt; delivery -&gt; Android enforcement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#451a03;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="940" width="820" height="105" as="geometry"/></mxCell><mxCell id="n6d4b278de186" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="nf7457612e72c" target="n2b13dbc88532"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ndb0b1ce820d4" value="12. Test business lifecycle: EMI -&gt; overdue -&gt; grace -&gt; final payment -&gt; decoupling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#451a03;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="940" width="820" height="105" as="geometry"/></mxCell><mxCell id="na22009aab423" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n2b13dbc88532" target="ndb0b1ce820d4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n51eb13be80c1" value="13. Test fraud/location/evidence/NEIR source signal -&gt; alert -&gt; UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#451a03;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="1100" width="820" height="105" as="geometry"/></mxCell><mxCell id="ncec4568c35cd" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="ndb0b1ce820d4" target="n51eb13be80c1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n36e18d5403ad" value="14. Record final failing file, endpoint, DB table, and log line before fixing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#451a03;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1120" y="1100" width="820" height="105" as="geometry"/></mxCell><mxCell id="n59359430f5e5" value="next" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#475569;fontColor=#334155;" edge="1" parent="1" source="n51eb13be80c1" target="n36e18d5403ad"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="neb6e75ff4f9a" value="This checklist is intentionally sequential. It prevents wasting time debugging UI symptoms when the backend, schema, or route prefix is broken." style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="120" y="1280" width="760" height="120" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="21-Known-Risks-and-Mismatches" name="21 Known Risks and Mismatches"><mxGraphModel dx="1545" dy="888" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1500" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="n96c03c5a5e43" value="Known Risks and Mismatches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="640" height="70" as="geometry"/></mxCell><mxCell id="n53d4f3935f1e" value="Concrete things found while reading the codebase" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#334155;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="35" width="880" height="60" as="geometry"/></mxCell><mxCell id="n534f12ea75ef" value="Admin path mismatch
Backend: /api/v1/admin/...
axios base already has /api/v1
Some code calls /api/admin/... or uses fetch helper without /api/v1
Likely source of 404s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#450a0a;fontStyle=1;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="80" y="150" width="477" height="260" as="geometry"/></mxCell><mxCell id="nce2ef495d440" value="Migration/schema risk
Duplicate old migration numbers and renamed legacy tables
099_unify_schema is critical
Code may assume status where DB has old state/payment_status/audit_log names" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#450a0a;fontStyle=1;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="581" y="150" width="477" height="260" as="geometry"/></mxCell><mxCell id="n8695e7e232e7" value="Redis behavior risk
Dev fallback MemoryStore can hide missing Redis
Production needs real Redis
Bull queues need createClient connections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#450a0a;fontStyle=1;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1082" y="150" width="477" height="260" as="geometry"/></mxCell><mxCell id="n27585c03dff2" value="Device Owner risk
Many lock features depend on actual Device Owner/DPC state
Normal debug install may not exercise full policy behavior" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#450a0a;fontStyle=1;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1583" y="150" width="477" height="260" as="geometry"/></mxCell><mxCell id="nc38d03f58e1e" value="Secrets/config risk
JWT, HMAC, PAUT/PADT/RTOC, DEVICE_TOKEN_SECRET, Firebase, AMAPI, SSL_PIN must align across backend and apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontColor=#4c0519;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="80" y="520" width="477" height="260" as="geometry"/></mxCell><mxCell id="nb6e491ff6749" value="Archive confusion risk
dealer-app-ARCHIVE, dealer-app-v2 (kiwi...), root android/lib folders may look active but are not the primary flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontColor=#4c0519;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="581" y="520" width="477" height="260" as="geometry"/></mxCell><mxCell id="n023233769ab6" value="PRD vs current code gap
PRD mentions Firebase Realtime DB and AMAPI as core; current code has FCM/AMAPI services but confirm implementation completeness before promising production behavior" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontColor=#4c0519;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1082" y="520" width="477" height="260" as="geometry"/></mxCell><mxCell id="ne0539731064c" value="ID meaning risk
Unified plan says dealer_id means dealer user id, matching dealers.user_id. Mixing dealer table id vs user id can break assignment/enrollment queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontColor=#4c0519;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="1583" y="520" width="477" height="260" as="geometry"/></mxCell><mxCell id="n2a793be7c9ee" value="Best next engineering move after this diagram: choose one failing symptom, trace it through the relevant use-case page, and fix only the first broken contract in the chain." style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="80" y="870" width="700" height="130" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
