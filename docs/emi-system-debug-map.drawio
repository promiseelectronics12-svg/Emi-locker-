Sends command" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#451a03;fontSize=12;spacing=10;" vertex="1" parent="1"><mxGeometry x="80" y="540" width="507" height="230" as="geometry"/></mxCell><mxCell id="n11a6f6000015" value="Flutter app
