# API Configuration
# Replace with real domain before deploy
API_BASE_URL=http://localhost:3000

# Provisioning Configuration
# Replace with real domain before deploy
QR_PROVISIONING_URL=http://localhost:3000/provisioning

# Network Configuration
CONNECT_TIMEOUT=30000
RECEIVE_TIMEOUT=30000
SEND_TIMEOUT=30000

# Security - Pinned SPKI Hashes (comma separated)
# Only active if API_BASE_URL does not contain 'localhost' or '10.0.2.2'
# PINNED_SPKI_HASHES=hash1,hash2

# Firebase Configuration (Replace with your actual values)
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
