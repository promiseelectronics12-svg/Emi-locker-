{
  "name": "emi-locker-backend",
  "version": "1.0.0",
  "description": "EMI Locker Platform Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.js",
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:critical": "eslint src/routes/dealer.js src/modules/deviceActivation/deviceRuntimeRoutes.js src/modules/enrollment/enrollmentRoutes.js src/modules/enrollment/enrollmentController.js src/modules/enrollment/enrollmentService.js src/modules/sse/sseService.js",
    "lint:fix": "eslint src/ --fix",
    "format:check": "prettier --check \"src/**/*.js\"",
    "format:critical": "prettier --check src/routes/dealer.js src/modules/deviceActivation/deviceRuntimeRoutes.js src/modules/enrollment/enrollmentRoutes.js src/modules/enrollment/enrollmentController.js src/modules/enrollment/enrollmentService.js src/modules/sse/sseService.js",
    "format:changed": "prettier --check",
    "format:fix": "prettier --write \"src/**/*.js\"",
    "migrate": "node scripts/migrate.js",
    "migrate:rollback": "node scripts/rollback.js",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "emi",
    "locker",
    "device-management",
    "android-enterprise"
  ],
  "author": "EMI Locker Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1045.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.12.3",
    "speakeasy": "^2.0.0",
    "twilio": "^4.23.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
