# Server Configuration
NODE_ENV=development
PORT=3000

# API Base URL - Replace with real domain before deploy
API_BASE_URL=http://localhost:3000

# Database - Replace with real credentials before deploy
DATABASE_URL=postgresql://user:password@localhost:5432/emi_locker
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emi_locker
DB_USER=
DB_PASSWORD=

# JWT - Generate strong random strings before deploy
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Encryption - Generate 256-bit keys before deploy
ENCRYPTION_KEY=
ENCRYPTION_ALGORITHM=aes-256-gcm

# Managed Redis — use ONE of the following (priority: Dragonfly > Upstash > REDIS_URL)
# The "rediss://" scheme (double-s) enables TLS automatically — required for cloud providers.

# Option A: DragonflyDB (highest throughput, recommended for 1 lakh+ devices)
# Get a free instance at: https://cloud.dragonflydb.io
# Format: rediss://default:<password>@<host>:<port>
DRAGONFLY_URL=

# Option B: Upstash Redis (good for current scale, pay-per-command pricing)
# From Upstash console → your database → "Redis Connect" → copy the rediss:// URL
# Format: rediss://default:<password>@<region>.upstash.io:<port>
UPSTASH_REDIS_URL=

# Option C: Any standard Redis URL (self-hosted or other managed provider)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS - Replace with real domains before deploy
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
ALLOW_LOCALHOST_CORS=true

# Admin Panel API - Replace with real domain before deploy
VITE_API_BASE_URL=http://localhost:3000

# Google AMAPI - Replace with real credentials before deploy
GOOGLE_AMAPI_PROJECT_ID=
GOOGLE_AMAPI_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_AMAPI_APPLICATION_CREDENTIALS=

# Firebase - Replace with real config before deploy
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_CERT_URL=
# Replace with real domain before deploy
FIREBASE_DATABASE_URL=
FIREBASE_WEBHOOK_API_KEY=

# Twilio SMS - Replace with real credentials before deploy
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMS (for OTP) - Replace with real credentials before deploy
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@emi-locker.local

# SMS (for OTP) - Replace with real credentials before deploy
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# BTRC NEIR Integration
NEIR_API_URL=
NEIR_API_KEY=
NEIR_REPORT_EMAIL=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Encryption key for device tokens - Generate 32-byte hex before deploy
DEVICE_TOKEN_SECRET=
DEVICE_TOKEN_EXPIRES_IN=30d
DEVICE_ACTIVATION_ALLOW_TEST_CODE=false
DEVICE_ACTIVATION_TEST_CODE=

# Admin credentials - Change these before deploy
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Security
BCRYPT_ROUNDS=12

# Lock Command Signing - Generate 256-bit hex secret before deploy
LOCK_COMMAND_SIGNING_SECRET=

# Server ID - Unique identifier for this server instance
SERVER_ID=server-001

# HMAC Secret - Use for key signing (REQUIRED for key module)
HMAC_SECRET=
HSM_KEY=

# Key Management Settings
KEY_EXPIRY_HOURS=72
VELOCITY_THRESHOLD=10
VELOCITY_WINDOW_HOURS=24
MAX_KEY_REQUEST_PERCENT=20

# PAUT (Pre-Authorized Unlock Token) - Generate random secret before deploy
PAUT_SIGNING_SECRET=

# PADT (Pre-Authorized Decouple Token) - Generate random secret before deploy
PADT_SIGNING_SECRET=

# RTOC (Release Token One-time Code) - Generate random secret before deploy
RTOC_SIGNING_SECRET=
# RTOC Encryption Key - Generate 256-bit hex key for AES-256-GCM encryption of RTOC codes
RTOC_ENCRYPTION_KEY=

# Grace Period (days)
GRACE_PERIOD_DAYS=7

# GPS radius for dealer shop proximity check (meters)
GPS_RADIUS_METERS=500

# Auto-lock cron schedule (default: daily at midnight)
AUTO_LOCK_CRON=0 0 * * *

# AMAPI Enterprise ID - Replace with real enterprise ID before deploy
AMAPI_ENTERPRISE_ID=
AMAPI_PROJECT_ID=
AMAPI_PRIVATE_KEY_ID=
AMAPI_PRIVATE_KEY=
AMAPI_CLIENT_EMAIL=
AMAPI_CLIENT_ID=

# Factory Reset Protection (FRP)
# FRP only works for Android Enterprise/device-owner enrolled devices.
# Add one or more admin-owned Google accounts, comma-separated.
FRP_ENABLED=true
FRP_ADMIN_OWNED_ACCOUNTS=

# Decoupling Settings
# Fraud review window in days (default: 5)
DECOUPLING_FRAUD_WINDOW_DAYS=5
# PADT expiry in days (default: 7)
DECOUPLING_PADT_EXPIRY_DAYS=7
# RTOC expiry in hours (default: 24)
DECOUPLING_RTOC_EXPIRY_HOURS=24
