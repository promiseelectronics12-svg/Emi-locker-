# EMI Locker User App - Environment Variables
# Copy this file to .env and fill in values before building

# =============================================================================
# API Configuration
# =============================================================================

# API Base URL for backend communication
# IMPORTANT: Replace with real domain before production deploy
# For Android emulator use: http://10.0.2.2:3000 (10.0.2.2 = host localhost)
# For physical device on same network: http://<your-machine-ip>:3000
API_BASE_URL=http://10.0.2.2:3000

# =============================================================================
# Certificate Pinning (Production Security)
# =============================================================================

# SSL Certificate Pin - SHA-256 fingerprint of server certificate
# REQUIRED: Replace with actual pin before production build
# To get the pin: openssl s_client -connect your-domain.com:443 | openssl x509 -pubkey | openssl dgst -sha256 -binary | base64
# IMPORTANT: pinning is DISABLED when API_BASE_URL contains localhost, 127.0.0.1, or 10.0.2.2
SSL_PIN=REPLACE_BEFORE_PRODUCTION_BUILD

# =============================================================================
# Environment
# =============================================================================

FLUTTER_ENV=development

# =============================================================================
# Firebase Configuration
# =============================================================================

# Replace with your Firebase project config values from Firebase Console
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=

# =============================================================================
# Google Play Integrity
# =============================================================================

# Play Integrity API key - Replace with real key before deploy
PLAY_INTEGRITY_API_KEY=

# =============================================================================
# DataStore Encryption
# =============================================================================

# Key alias for Android Keystore encryption
# Default should work for most cases
DATASTORE_KEY_ALIAS=emilocker_datastore_key

# =============================================================================
# Lock State Configuration
# =============================================================================

# Lock state transitions are computed locally from EMI schedule in Room DB
# Server can override via FCM STATE_CHANGE commands
# All lock state URLs use API_BASE_URL — no hardcoded domains

# =============================================================================
# PAUT/PADT Token System
# =============================================================================

# Pre-Authorized Unlock Tokens (PAUT):
# - 48 hour validity
# - Stored encrypted in DataStore via Android Keystore
# - Signed JWT with HMAC-SHA256 using server's RSA public key
# - Used for offline unlock when FCM fails

# Pre-Authorized Decouple Tokens (PADT):
# - 7 day validity
# - Full device decouple when FCM decouple fails
# - Customer visits dealer to push via Dealer App

# Server public key for token verification stored automatically when PAUT is requested