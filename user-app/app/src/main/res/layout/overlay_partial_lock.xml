<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="@color/state_partial_lock" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/overlay_partial_lock_title"
                android:textColor="@color/state_partial_lock"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPartialLockDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvPartialLockAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/state_partial_lock"
                android:textSize="24sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/overlay_dealer_label"
                android:textColor="#757575"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvPartialLockDealerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPartialLockDealerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="#757575"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnPartialLockPay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/state_partial_lock"
                android:text="@string/btn_pay_now"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPartialLockCallDealer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@android:color/transparent"
                android:text="@string/btn_contact_dealer"
                android:textColor="@color/state_partial_lock"
                android:textSize="14sp"
                style="?android:attr/borderlessButtonStyle" />

            <EditText
                android:id="@+id/etPartialLockOfflineOtp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:hint="Offline unlock code"
                android:inputType="number"
                android:maxLength="6"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnPartialLockOfflineUnlock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/state_partial_lock"
                android:text="Unlock with OTP"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPartialLockEmergency"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@android:color/transparent"
                android:text="@string/btn_emergency"
                android:textColor="@color/error"
                android:textSize="14sp"
                style="?android:attr/borderlessButtonStyle" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
