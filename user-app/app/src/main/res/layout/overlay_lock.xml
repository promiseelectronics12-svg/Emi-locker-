<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Lock Icon -->
    <ImageView
        android:id="@+id/iv_overlay_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_notification"
        app:tint="@color/overlay_text" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_overlay_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:textColor="@color/overlay_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_overlay_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:textColor="@color/overlay_text"
        android:textSize="16sp" />

    <!-- Pay Now Button -->
    <Button
        android:id="@+id/btn_overlay_pay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/overlay_button"
        android:text="@string/btn_pay_now"
        android:textColor="@color/overlay_button_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Contact Dealer Button -->
    <Button
        android:id="@+id/btn_overlay_contact_dealer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@android:color/transparent"
        android:text="@string/btn_contact_dealer"
        android:textColor="@color/overlay_text"
        android:textSize="16sp"
        android:visibility="gone"
        style="?android:attr/borderlessButtonStyle" />

    <!-- Dismiss Button (only for reminder/warning) -->
    <Button
        android:id="@+id/btn_overlay_dismiss"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@android:color/transparent"
        android:text="@string/btn_dismiss"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        style="?android:attr/borderlessButtonStyle" />

</LinearLayout>
