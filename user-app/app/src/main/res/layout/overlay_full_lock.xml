<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/state_full_lock"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        app:tint="@color/white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="@string/overlay_full_lock_title"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFullLockDays"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvFullLockAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#44FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/overlay_contact_your_dealer"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvFullLockDealerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFullLockDealerPhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textColor="#CCFFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnFullLockCallDealer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/white"
        android:text="@string/btn_call_dealer"
        android:textColor="@color/state_full_lock"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etFullLockOfflineOtp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/white"
        android:gravity="center"
        android:hint="Offline unlock code"
        android:inputType="number"
        android:maxLength="6"
        android:textColor="@color/white"
        android:textColorHint="#BBFFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnFullLockOfflineUnlock"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/white"
        android:text="Unlock with OTP"
        android:textColor="@color/state_full_lock"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
