<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Phone support for dealer contact. SMS/call-log permissions are production-policy gated. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <!-- IMEI reading for device binding — DPM.getImei() used on Android 10+ when Device Owner -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Overlay setup is tested through the normal Android settings screen. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Used by reminder watermark to detect foreground payment apps so the
         overlay auto-hides when customer opens bKash/Nagad/Rocket to pay.
         Granted automatically via AppOps when Device Owner is active. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Camera (for potential verification) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Vibration for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />
        <package android:name="com.bKash.customerapp" />
        <package android:name="com.konasl.nagad" />
        <package android:name="com.dbbl.mbs.apps.main" />
        <package android:name="bd.com.upay.customer" />
        <package android:name="com.ibbl.cellfin" />
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <intent>
            <action android:name="android.settings.WIFI_SETTINGS" />
        </intent>
    </queries>

    <!-- Required for accessibility service fallback enrollment on non-Device Owner installs. -->
    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".EMILockerApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmiLocker"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <!-- Auth Activity — launcher, handles login and register flow -->
        <activity
            android:name=".presentation.AuthActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Dashboard Activity — shown after successful authentication -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:lockTaskMode="if_whitelisted" />

        <activity
            android:name=".presentation.KioskLockActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:lockTaskMode="if_whitelisted"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <!-- Android 12+ Device Owner provisioning callbacks.
             Setup Wizard asks these before completing fully managed enrollment. -->
        <activity
            android:name=".provisioning.ProvisioningModeActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.app.action.GET_PROVISIONING_MODE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.app.action.ADMIN_POLICY_COMPLIANCE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Device Admin Receiver -->
        <receiver
            android:name=".device.DeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
        </receiver>

        <!-- Persistent Foreground Service -->
        <service
            android:name=".service.EmiLockerService"
            android:exported="false"
            android:foregroundServiceType="location|specialUse"
            android:stopWithTask="false" />

        <!-- Boot Completed Receiver for auto-start -->
        <receiver
            android:name=".device.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Shutdown Receiver — captures GPS and shows fake shutdown overlay -->
        <receiver
            android:name=".device.ShutdownReceiver"
            android:exported="false">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.ACTION_SHUTDOWN" />
            </intent-filter>
        </receiver>

        <!-- Fake shutdown overlay — shown during ACTION_SHUTDOWN to buy time for GPS ping -->
        <activity
            android:name=".presentation.FakeShutdownActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen" />

        <!-- Diagnostic receiver — responds to ADB broadcast commands -->
        <receiver
            android:name=".diagnostic.DiagnosticReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.android.simtoolkit.DIAG" />
            </intent-filter>
        </receiver>

        <!-- Diagnostic screen — launched via ADB am start -->
        <activity
            android:name=".diagnostic.DiagnosticActivity"
            android:exported="true"
            android:label="Diagnostic" />

        <receiver
            android:name=".overlay.DebugOverlayReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.android.simtoolkit.DEBUG_SHOW_OVERLAY" />
                <action android:name="com.android.simtoolkit.DEBUG_HIDE_OVERLAY" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".sms.OfflineUnlockSmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- FCM Messaging Service -->
        <service
            android:name=".fcm.EmiLockerFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- WorkManager Worker for background EMI schedule checks -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Dealer Contact Activity — accessible even in Full Lock mode via lockTaskPackages -->
        <activity
            android:name=".ui.dealer.DealerContactActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTask"
            android:lockTaskMode="if_whitelisted" />

        <!-- Agreement Detail Activity — for viewing EMI agreement PDF -->
        <activity
            android:name=".presentation.screens.agreement.AgreementDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTask" />

        <!-- Dealer types activation code here during enrollment -->
        <activity
            android:name=".presentation.ActivationScreen"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize" />


        <!-- Accessibility Service — monitors foreground windows during FULL_LOCK to block
             app-switching and kiosk escape on MIUI/HyperOS devices -->
        <service
            android:name=".service.EmiLockerAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- FCM Default Channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="emi_locker_default" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />

    </application>

</manifest>
